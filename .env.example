# ──────────────────────────────────────────────────────────────────────────────
# AIP — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── AI Model API Keys ─────────────────────────────────────────────────────────
# OpenAI — used by all agents and for daily brief generation (GPT-5.4)
OPENAI_API_KEY=your_openai_api_key_here

# Claude — set ONE of the following:
#   ANTHROPIC_API_KEY  : direct Anthropic access (preferred)
#   OPENROUTER_API_KEY : OpenRouter unified gateway (sk-or-v1-... keys)
# The platform will use whichever is set; ANTHROPIC_API_KEY takes priority.
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Override the OpenRouter model name for Claude (default: anthropic/claude-opus-4-5)
# OPENROUTER_CLAUDE_MODEL=anthropic/claude-opus-4-5

# Google Gemini 3.6 Pro
GEMINI_API_KEY=your_gemini_api_key_here

# ── Data Sources ──────────────────────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key_here

# ── Database ──────────────────────────────────────────────────────────────────
# For local development (SQLite):
DB_PATH=aip.db

# For production (PostgreSQL) — set this to override DB_PATH:
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong random secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here_min_32_characters

# Token expiry
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Authentication is REQUIRED by default (REQUIRE_AUTH=true).
# Set to "false" only for local development — never in production.
REQUIRE_AUTH=true

# Initial admin user — created automatically on first startup when both are set.
# Leave blank after the first run (the account persists in the database).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_on_first_login

# ── Encryption ────────────────────────────────────────────────────────────────
# Field-level Fernet encryption for sensitive database columns.
# Generate a key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty to disable encryption (development only).
ENCRYPTION_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Production (auren-workspace.com):
#   ALLOWED_ORIGINS=https://auren-workspace.com,https://www.auren-workspace.com
ALLOWED_ORIGINS=http://localhost:3000

# ── Error Monitoring (Sentry) ─────────────────────────────────────────────────
# Leave empty to disable Sentry.
SENTRY_DSN=

# ── Frontend ──────────────────────────────────────────────────────────────────
# Set in frontend/.env.local (not here).
# Production (auren-workspace.com): https://api.auren-workspace.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Outbound Alert Notifications ──────────────────────────────────────────────
# Email recipients for high-priority market alerts (comma-separated).
ALERT_EMAIL_TO=

# SMTP configuration for sending alert emails.
# Works with any SMTP provider (SendGrid, Postmark, Gmail, etc.)
# SendGrid example: SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_USER=apikey  SMTP_PASSWORD=<api_key>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@auren-workspace.com

# HTTP webhook URL to receive alert payloads (POST JSON).
# Leave empty to disable webhook delivery.
ALERT_WEBHOOK_URL=

# Minimum alert severity that triggers email/webhook delivery.
# Values: info | warning | critical  (default: warning)
ALERT_MIN_SEVERITY=warning

# ── Agent configuration ───────────────────────────────────────────────────────
# Agents use GPT-5.4 (OPENAI_API_KEY) for all reasoning tasks.
# Market consensus uses GPT-5.4, Claude Opus 4.6 (via Anthropic or OpenRouter),
# and Gemini 3.6 Pro in a multi-model debate loop.
# Scheduled jobs run automatically on startup:
#   Orchestrator : daily briefing @ 09:00
#   Marketing    : daily teaser @ 08:30, lead nurture every 2 h
#   Market Intel : pre-market @ 07:00, close summary @ 16:30
#   Customer     : daily check @ 10:00
#   Analytics    : KPI report @ 08:00, anomaly check every 4 h
